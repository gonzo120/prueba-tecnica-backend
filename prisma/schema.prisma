// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MerchantStatus {
  active
  inactive
}

enum TransactionStatus {
  pending
  approved
  rejected
  failed
  completed
}

enum TransactionType {
  payin
  payout
}

enum Currency {
  GTQ
  COP
  USD
}

enum SettlementStatus {
  pending
  processed
  paid
}

model Merchant {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  api_key        String          @unique
  status         MerchantStatus  @default(active)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  
  transactions   Transaction[]
  settlements    Settlement[]
  
  @@index([api_key])
  @@index([email])
}

model Transaction {
  id             String           @id @default(uuid())
  merchant_id    String
  merchant       Merchant         @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(12, 2)
  currency       Currency
  type           TransactionType
  status         TransactionStatus @default(pending)
  reference      String           @unique
  metadata       Json?            @db.JsonB
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  
  settlement_transactions SettlementTransaction?
  
  @@index([merchant_id])
  @@index([status])
  @@index([created_at])
  @@index([merchant_id, status])
}

model Settlement {
  id                String          @id @default(uuid())
  merchant_id       String
  merchant          Merchant        @relation(fields: [merchant_id], references: [id], onDelete: Cascade)
  total_amount      Decimal         @db.Decimal(14, 2)
  transaction_count Int
  status            SettlementStatus @default(pending)
  period_start      DateTime
  period_end        DateTime
  created_at        DateTime        @default(now())
  
  transactions      SettlementTransaction[]
  
  @@index([merchant_id])
  @@index([status])
  @@index([period_start, period_end])
}

model SettlementTransaction {
  settlement_id    String
  settlement       Settlement @relation(fields: [settlement_id], references: [id], onDelete: Cascade)
  transaction_id   String     @unique
  transaction      Transaction @relation(fields: [transaction_id], references: [id])
  
  @@id([settlement_id, transaction_id])
  @@index([transaction_id])
}